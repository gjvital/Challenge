{
  "name": "constellation-qa-challenge",
  "version": "1.0.0",
  "description": "API and UI test automation suite for Constellation Automotive Group take-home challenge",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui",
    "test:headed": "playwright test --project=ui --headed",
    "report": "playwright show-report"
  },
  "keywords": ["playwright", "api-testing", "e2e", "qa"],
  "author": "Gabriel Vital",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.52.0",
    "@types/node": "^22.15.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.3"
  }
}
